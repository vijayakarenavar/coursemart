# CourseMart Environment Variables
# Copy this file to .env and fill in the values

# API Base URL (Production)
API_BASE_URL=https://course.mart.lemmecode.com/api/v1

# API Base URL (Development - uncomment for local testing)
# API_BASE_URL=http://localhost:8000/api/v1

# Media Base URL (for images, videos, notes)
MEDIA_BASE_URL=https://course.mart.lemmecode.com

# App Environment (development | production)
APP_ENV=development

# Secure Storage Key for JWT Token
STORAGE_KEY_AUTH_TOKEN=auth_token
